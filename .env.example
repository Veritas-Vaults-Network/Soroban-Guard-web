NEXT_PUBLIC_API_URL=http://localhost:3001

# API authentication — set a secret to require Bearer token on /api/results and /api/webhook.
# Leave unset in local dev to bypass auth.
API_SECRET_KEY=

# Vercel KV — set these to persist /api/results and /api/webhook across cold starts.
# Leave unset to fall back to in-memory storage (suitable for local dev).
KV_REST_API_URL=
KV_REST_API_TOKEN=
